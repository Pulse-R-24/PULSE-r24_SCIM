# Root environment variables for PULSE-R24

# Prisma uses SQLite in the current local/demo schema.
DATABASE_URL="file:./dev.db"
DIRECT_URL=

# Auth.js session/JWT secret. Use a long random value outside local demos.
AUTH_SECRET="replace_with_a_long_random_secret"

# Optional storage/email integrations. Leave blank for local UI workflow testing.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

# Worker infrastructure is reserved for later phases. Not required for current UI QA.
REDIS_URL="redis://127.0.0.1:6379"

# Reserved for future AI integrations. Do not configure for the current demo phase.
GROQ_API_KEY=
GEMINI_API_KEY=

# Seeded demo accounts.
ADMIN_EMAIL="admin@pulse-r24.local"
ADMIN_PASSWORD="SuperSecret123!"
ADMIN_NAME="Super Admin"
DEMO_PASSWORD="DemoPass123!"
DEMO_ANALYST_EMAIL="analyst@pulse-r24.local"
DEMO_EDITOR_EMAIL="editor@pulse-r24.local"
DEMO_REVIEWER_EMAIL="reviewer@pulse-r24.local"
DEMO_PUBLISHER_EMAIL="publisher@pulse-r24.local"

NODE_ENV="development"
LOG_LEVEL="debug"
