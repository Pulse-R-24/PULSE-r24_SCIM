# Root environment variables for PULSE-R24 RC1
# Prisma uses the NEW PULSE-r24_SCIM Supabase Postgres database.
# Use the connection string from the new Supabase project only.
# For local RC1 setup and prisma db push, use the direct/session connection URL.
DATABASE_URL="postgresql://postgres.<new-project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL=""

# Auth.js session/JWT secret. Use a long random value outside local demos.
AUTH_SECRET="replace_with_a_long_random_secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage for evidence uploads.
# Create/use a private bucket named "evidence" in the same NEW PULSE-r24_SCIM Supabase project.
SUPABASE_URL="https://<new-project-ref>.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY="replace_with_new_project_service_role_key"

# Public Protomaps PMTiles URL for India map.
# Example:
# NEXT_PUBLIC_PROTOMAPS_PM_TILES_URL="https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/maps/india_z7.pmtiles"
NEXT_PUBLIC_PROTOMAPS_PM_TILES_URL=

# Seeded demo accounts.
ADMIN_EMAIL="admin@pulse-r24.local"
ADMIN_PASSWORD="SuperSecret123!"
ADMIN_NAME="Super Admin"
DEMO_PASSWORD="DemoPass123!"
DEMO_ANALYST_EMAIL="analyst@pulse-r24.local"
DEMO_EDITOR_EMAIL="editor@pulse-r24.local"
DEMO_REVIEWER_EMAIL="reviewer@pulse-r24.local"
DEMO_PUBLISHER_EMAIL="publisher@pulse-r24.local"

NODE_ENV="development"
LOG_LEVEL="debug"
