generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  name            String?
  avatar_url      String?
  hashed_password String?
  accounts        Account[]
  sessions        Session[]
  roles           UserRole[]
  
  // Relations to Report
  reports           Report[]    @relation("author_reports")
  reports_created   Report[]    @relation("report_created_by")
  reports_updated   Report[]    @relation("report_updated_by")
  reports_locked    Report[]    @relation("report_locked_by")
  
  // Relations to ReportRevision
  revisions_created ReportRevision[] @relation("revision_created_by")

  // Relations to Category
  categories_created Category[]   @relation("category_created_by")
  categories_updated Category[]   @relation("category_updated_by")

  // Relations to Tag
  tags_created      Tag[]         @relation("tag_created_by")
  tags_updated      Tag[]         @relation("tag_updated_by")

  // Relations to Media
  media_uploaded    Media[]       @relation("media_uploaded_by")
  media_updated     Media[]       @relation("media_updated_by")

  // Relations to Evidence
  evidence_created  Evidence[]    @relation("evidence_created_by")
  evidence_updated  Evidence[]    @relation("evidence_updated_by")

  // Relations to ReviewComment
  comments_created  ReviewComment[] @relation("comment_created_by")
  comments_updated  ReviewComment[] @relation("comment_updated_by")

  // Relations to ReviewAssignment
  assignments_assigned ReviewAssignment[] @relation("reviewer_assignments")
  assignments_created  ReviewAssignment[] @relation("assignment_created_by")
  assignments_updated  ReviewAssignment[] @relation("assignment_updated_by")

  // Relations to WorkflowHistory
  history_created   WorkflowHistory[] @relation("history_actor")
  history_updated   WorkflowHistory[] @relation("history_updated_by")

  // Notifications and Activity
  notifications     Notification[]    @relation("user_notifications")
  activities        ActivityFeed[]    @relation("activity_actor")

  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  @@map("users")
}

model Account {
  id                 String   @id @default(cuid())
  user               User     @relation(fields: [userId], references: [id])
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  expires      DateTime

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  users       UserRole[]
  created_at  DateTime         @default(now())

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]
  created_at  DateTime         @default(now())

  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role       @relation(fields: [roleId], references: [id])
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Report {
  id              String           @id @default(uuid())
  title           String
  slug            String           @unique
  body_markdown   String
  
  author          User?            @relation("author_reports", fields: [authorId], references: [id])
  authorId        String?
  
  status          WorkflowState    @relation(fields: [workflowStateId], references: [id])
  workflowStateId String

  revisions       ReportRevision[]
  categories      ReportCategory[]
  tags            ReportTag[]
  media           Media[]
  
  comments        ReviewComment[]
  assignments     ReviewAssignment[]
  history         WorkflowHistory[]
  evidence        Evidence[]       @relation("report_evidence")
  evidenceFile    EvidenceFile[]

  // Soft delete and audit tracking:
  deleted_at      DateTime?
  createdById     String?
  created_by      User?            @relation("report_created_by", fields: [createdById], references: [id])
  updatedById     String?
  updated_by      User?            @relation("report_updated_by", fields: [updatedById], references: [id])

  // Editing lock fields:
  lockedById      String?
  locked_by       User?            @relation("report_locked_by", fields: [lockedById], references: [id])
  locked_at       DateTime?

  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  @@index([title])
  @@map("reports")
}

model ReportRevision {
  id            String   @id @default(uuid())
  report        Report   @relation(fields: [reportId], references: [id])
  reportId      String
  summary       String?
  body_markdown String
  created_by    User?    @relation("revision_created_by", fields: [createdById], references: [id])
  createdById   String?
  created_at    DateTime @default(now())

  @@map("report_revisions")
}

model Category {
  id      String          @id @default(uuid())
  name    String          @unique
  reports ReportCategory[]

  // Soft delete and audit tracking:
  deleted_at  DateTime?
  createdById String?
  created_by  User?     @relation("category_created_by", fields: [createdById], references: [id])
  updatedById String?
  updated_by  User?     @relation("category_updated_by", fields: [updatedById], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@map("categories")
}

model Tag {
  id      String       @id @default(uuid())
  name    String       @unique
  reports ReportTag[]

  // Soft delete and audit tracking:
  deleted_at  DateTime?
  createdById String?
  created_by  User?     @relation("tag_created_by", fields: [createdById], references: [id])
  updatedById String?
  updated_by  User?     @relation("tag_updated_by", fields: [updatedById], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@map("tags")
}

model ReportCategory {
  id         String   @id @default(uuid())
  report     Report   @relation(fields: [reportId], references: [id])
  reportId   String
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  @@unique([reportId, categoryId])
  @@map("report_categories")
}

model ReportTag {
  id       String @id @default(uuid())
  report   Report @relation(fields: [reportId], references: [id])
  reportId String
  tag      Tag    @relation(fields: [tagId], references: [id])
  tagId    String

  @@unique([reportId, tagId])
  @@map("report_tags")
}

model Media {
  id           String   @id @default(uuid())
  bucket       String
  path         String
  mime_type    String
  size         Int
  uploaded_by  User?    @relation("media_uploaded_by", fields: [uploadedById], references: [id])
  uploadedById String?
  created_at   DateTime @default(now())

  // tracking:
  updatedById String?
  updated_by  User?    @relation("media_updated_by", fields: [updatedById], references: [id])

  evidence     Evidence[]
  evidenceFile EvidenceFile[]
  reports      Report[]

  @@index([bucket])
  @@map("media")
}

model EvidenceFile {
  id         String   @id @default(uuid())
  report     Report   @relation(fields: [reportId], references: [id])
  reportId   String
  media      Media    @relation(fields: [mediaId], references: [id])
  mediaId    String
  note       String?
  created_at DateTime @default(now())

  @@map("evidence_files")
}

model Evidence {
  id          String    @id @default(uuid())
  reportId    String
  report      Report    @relation("report_evidence", fields: [reportId], references: [id], onDelete: Cascade)
  mediaId     String?
  media       Media?    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  title       String
  description String?
  url         String?   // external link
  
  // Soft delete and audit tracking:
  deleted_at  DateTime?
  createdById String?
  created_by  User?     @relation("evidence_created_by", fields: [createdById], references: [id])
  updatedById String?
  updated_by  User?     @relation("evidence_updated_by", fields: [updatedById], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@map("evidence")
}

model Source {
  id         String   @id @default(uuid())
  name       String
  url        String?
  created_at DateTime @default(now())

  @@map("sources")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entity     String?
  entityId   String?
  meta       String?
  created_at DateTime @default(now())

  @@index([actorId])
  @@map("audit_logs")
}

model WorkflowState {
  id      String  @id @default(uuid())
  key     String  @unique
  label   String
  reports Report[]

  @@map("workflow_states")
}

model ReviewComment {
  id         String   @id @default(uuid())
  report     Report   @relation(fields: [reportId], references: [id])
  reportId   String
  author     User?    @relation("comment_created_by", fields: [authorId], references: [id])
  authorId   String?
  body       String
  created_at DateTime @default(now())

  // tracking:
  updatedById String?
  updated_by  User?    @relation("comment_updated_by", fields: [updatedById], references: [id])
  updated_at  DateTime @updatedAt

  @@map("review_comments")
}

model ReviewAssignment {
  id           String   @id @default(uuid())
  report       Report   @relation(fields: [reportId], references: [id])
  reportId     String
  reviewer     User     @relation("reviewer_assignments", fields: [reviewerId], references: [id])
  reviewerId   String
  assigned_at  DateTime @default(now())
  completed_at DateTime?

  // tracking:
  createdById  String?
  created_by   User?    @relation("assignment_created_by", fields: [createdById], references: [id])
  updatedById  String?
  updated_by   User?    @relation("assignment_updated_by", fields: [updatedById], references: [id])

  @@map("review_assignments")
}

model WorkflowHistory {
  id         String   @id @default(uuid())
  report     Report   @relation(fields: [reportId], references: [id])
  reportId   String
  action     String
  actorId    String?
  actor      User?    @relation("history_actor", fields: [actorId], references: [id])
  meta       String?
  created_at DateTime @default(now())

  // tracking:
  updatedById String?
  updated_by  User?    @relation("history_updated_by", fields: [updatedById], references: [id])

  @@map("workflow_history")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("user_notifications", fields: [userId], references: [id], onDelete: Cascade)
  title       String
  body        String
  read        Boolean  @default(false)
  type        String   // e.g. "WORKFLOW_STATE_CHANGE", "ASSIGNMENT", "COMMENT"
  meta        String?  // e.g. { reportId: "...", authorId: "..." }
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([userId])
  @@map("notifications")
}

model ActivityFeed {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation("activity_actor", fields: [actorId], references: [id], onDelete: Cascade)
  action     String   // e.g., "created_report", "status_changed", "submitted_review"
  entityType String   // e.g., "REPORT", "COMMENT", "MEDIA"
  entityId   String?
  meta       String?
  created_at DateTime @default(now())

  @@index([actorId])
  @@map("activity_feed")
}

