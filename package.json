{
  "name": "pulse-r24",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --concurrency 1",
    "build": "turbo run build",
    "lint": "turbo run lint",
