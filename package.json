    "eslint": "^8.57.0",
    "next": "^15.0.0",
    "postcss": "^8.5.15",
    "prisma": "^5.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.13",
    "ts-node": "^10.9.1",
