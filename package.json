{
  "name": "pulse-r24",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "modules",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @pulse-r24/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "node --test tests/**/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "prisma:generate": "prisma generate --schema packages/database/prisma/schema.prisma",
    "db:push": "node ./scripts/db/pushSchema.js",
    "seed:workflow": "node ./scripts/seed/seedWorkflowStates.js",
    "seed:roles": "node ./scripts/seed/seedRoles.js",
    "seed:bootstrap": "node ./scripts/seed/seedBootstrap.js",
    "seed:demo": "node ./scripts/seed/seedBootstrap.js"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.10.0",
    "@supabase/supabase-js": "^2.25.0",
    "@tanstack/react-query": "^5.100.14",
    "bcryptjs": "^2.4.3",
    "bullmq": "^3.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "file-type": "^18.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "pino": "^8.10.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.18",
    "next": "^15.0.0",
    "postcss": "^8.5.15",
    "prisma": "^5.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.13",
    "ts-node": "^10.9.1",
    "turbo": "^1.10.0",
    "typescript": "^5.5.0"
  }
}
